{
    "version": 2,
    "outputDirectory": "dist/public",
    "functions": {
        "api/**/*.ts": {
            "includeFiles": "server/resources/templates/**",
            "maxDuration": 60,
            "memory": 1024
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.ts"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}